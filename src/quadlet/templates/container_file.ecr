[Container]
Image=<%= @image %>
ContainerName=<%= @service %>-<%= @color.slug %>
Network=<%= @service %>.network
<% @environment.each do |key, value| %>
Environment=<%= key %>=<%= value %>
<% end %>
<% if command = @command %>
Exec=<%= command %>
<% end %>

[Service]
Restart=always

[Install]
WantedBy=default.target
